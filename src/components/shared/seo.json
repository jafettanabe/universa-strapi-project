{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "seo",
    "description": "Reusable SEO fields"
  },
  "attributes": {
    "metaTitle": {
      "type": "string"
    },
    "metaDescription": {
      "type": "text"
    },
    "metaImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "noIndex": {
      "type": "boolean",
      "default": false
    },
    "canonicalUrl": {
      "type": "string"
    }
  }
}
