{
  "kind": "collectionType",
  "collectionName": "faq_items",
  "info": {
    "singularName": "faq-item",
    "pluralName": "faq-items",
    "displayName": "FAQ Item"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "question": {
      "type": "string",
      "required": true
    },
    "answer": {
      "type": "richtext",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "general",
        "programas",
        "pagos",
        "horarios",
        "metodologia",
        "certificacion",
        "empresas"
      ],
      "default": "general"
    },
    "relatedPrograms": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::program.program",
      "inversedBy": "faqItems"
    },
    "displayOrder": {
      "type": "integer",
      "default": 0
    },
    "featured": {
      "type": "boolean",
      "default": false
    }
  }
}
