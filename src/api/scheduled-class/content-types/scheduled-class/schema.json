{
  "kind": "collectionType",
  "collectionName": "scheduled_classes",
  "info": {
    "singularName": "scheduled-class",
    "pluralName": "scheduled-classes",
    "displayName": "Clases Programadas",
    "description": "Sección para programar clases por programa, horario y profesor."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string"
    },
    "level": {
      "type": "enumeration",
      "enum": [
        "Básico",
        "Intermedio",
        "Intermedio Alto",
        "Avanzado",
        "Mixto"
      ],
      "default": "Básico"
    },
    "day": {
      "type": "string"
    },
    "schedule": {
      "type": "string",
      "required": true
    },
    "teacher": {
      "type": "string",
      "required": false
    },
    "isFull": {
      "type": "boolean",
      "default": false
    },
    "whatsappNumber": {
      "type": "string"
    },
    "program": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::program.program",
      "inversedBy": "scheduledClasses"
    }
  }
}
