{
  "kind": "collectionType",
  "collectionName": "job_openings",
  "info": {
    "singularName": "job-opening",
    "pluralName": "job-openings",
    "displayName": "Job Opening"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "department": {
      "type": "string"
    },
    "modality": {
      "type": "enumeration",
      "enum": [
        "remoto",
        "presencial",
        "hibrido"
      ]
    },
    "location": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "requirements": {
      "type": "richtext"
    },
    "applyUrl": {
      "type": "string"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    }
  }
}
